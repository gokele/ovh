# ==============================================
# OVH 控制台 (Go server) - 配置文件
# 复制此文件为 .env 并修改配置值
# ==============================================

# API 安全密钥（用于验证前后端通信）
# 生成方法: openssl rand -base64 32
# 与前端设置页中的密钥保持一致
API_SECRET_KEY=123456

# 后端端口
PORT=19998

# 调试模式（开发: true, 生产: false）
DEBUG=false

# 是否启用 API 密钥验证
ENABLE_API_KEY_AUTH=true

# 监听地址。默认空 = 所有网卡（localhost / 127.0.0.1 / 局域网 IP 都能访问）
# 想锁回环写 127.0.0.1；公网部署写 0.0.0.0
LISTEN_HOST=

# Gin 模式: debug / release
GIN_MODE=release
